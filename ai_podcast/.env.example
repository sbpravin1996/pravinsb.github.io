# AI Podcast Pipeline Configuration
# Copy to .env and fill in your values

# === LLM (Script Generation) ===
# Use Ollama for local, or OpenAI-compatible API
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2

# For OpenAI or compatible API:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# === TTS (Higgs 2.5) ===
# Higgs 2.5 via DeepInfra - get token at https://deepinfra.com
TTS_PROVIDER=higgs
DEEPINFRA_API_KEY=your_deepinfra_token

# Or use local fallback (pyttsx3 - lower quality)
# TTS_PROVIDER=pyttsx3

# === Paths ===
OUTPUT_DIR=output
TEMP_DIR=temp
