# RAG Configuration
# Copy to .env and adjust as needed

# Embedding model (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Ollama model
OLLAMA_MODEL=llama3.2

# ChromaDB persist path (relative to project root)
CHROMA_PERSIST_DIR=chroma_db

# Data directory (PDFs)
DATA_DIR=data

# Chunk settings
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Retrieval
TOP_K=4
